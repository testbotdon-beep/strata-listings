# ─── Upstash Redis (primary datastore) ────────────────────
# Provisioned via Vercel Marketplace → Upstash Redis.
# Env var prefix is `storage_` (set during install).
storage_KV_REST_API_URL=
storage_KV_REST_API_TOKEN=

# ─── Auth.js ───────────────────────────────────────────────
AUTH_SECRET=

# ─── Stripe (subscription billing) ─────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# The price ID for the $79/mo Strata Listings Pro plan
# (create at https://dashboard.stripe.com/products)
STRIPE_PRICE_ID=
# Webhook signing secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=

# ─── Promo codes ───────────────────────────────────────────
# Comma-separated list of codes that activate an agent without payment.
# Used primarily to give Strata subscribers free access during launch.
# Default if unset: STRATA,STRATADEMO
PROMO_CODES=STRATA,STRATADEMO

# ─── Admin activation ─────────────────────────────────────
# Token for POST /api/admin/activate — used by Playwright tests
# and manual agent activation. Set to any secure random string.
ADMIN_TOKEN=

# ─── Lead routing (optional) ───────────────────────────────
LEAD_WEBHOOK_URL=

# ─── Strata integration (phase 2) ──────────────────────────
STRATA_API_URL=
STRATA_API_KEY=
